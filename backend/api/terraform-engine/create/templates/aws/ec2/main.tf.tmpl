data "aws_ssm_parameter" "{{.ResourceName}}_ami" {
  name = "/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-default-x86_64"
}

resource "aws_instance" "{{.ResourceName}}" {
  ami           = data.aws_ssm_parameter.{{.ResourceName}}_ami.value
  instance_type = "{{.InstanceType}}"
{{- if .KeyName}}
  key_name = "{{.KeyName}}"
{{- end}}

  tags = {
    Name = "{{.ResourceName}}"
  }
}
